# Database
# For Supabase, prefer using the connection string from:
# Project Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres
SUPABASE_DB_URL=
DB_SSL=true

# Fallback Postgres fields (used when DATABASE_URL/SUPABASE_DB_URL is empty)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=restaurant_db

# Supabase client/public variables (not used by this NestJS backend for TypeORM)
VITE_SUPABASE_PROJECT_ID=your-project-ref
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=1h
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRATION=7d
SUPABASE_JWT_SECRET=

# App
PORT=3000
NODE_ENV=development

# Tax rate (percentage)
TAX_RATE=10
